FROM_EMAIL=
EMAIL_PASSWORD=
TO_EMAIL=
# Optional: sender display name used in the "From" header
# FROM_NAME=arXiv Daily Bot
# Optional: arXiv API page size (1..2000). Larger is faster but can be heavier.
# ARXIV_PAGE_SIZE=200
# Optional: print output instead of sending
# DRY_RUN=1
# Optional: split emails to keep body small enough for SMTP providers
# MAX_EMAIL_CHARS=80000
